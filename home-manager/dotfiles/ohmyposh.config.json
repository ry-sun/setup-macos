{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "iterm_features": [
    "prompt_mark",
    "remote_host",
    "current_dir"
  ],
  "final_space": true,
  "version": 4,
  "async": true,
  "blocks": [
    {
      "alignment": "right",
      "type": "prompt",
      "overflow": "hide",
      "segments": [
        {
          "type": "status",
          "background": "#2e9599",
          "background_templates": [
            "{{ if gt .Code 0 }}red{{ end }}"
          ],
          "foreground": "#ffffff",
          "options": {
            "always_enabled": true
          },
          "style": "diamond",
          "leading_diamond": "Óā∂",
          "template": " {{ if gt .Code 0 }}Ôź°{{ else }}ÔĎ©{{ end }} "
        },
        {
          "type": "executiontime",
          "background": "#83769c",
          "foreground": "#ffffff",
          "powerline_symbol": "Óāį",
          "options": {
            "always_enabled": true
          },
          "style": "powerline",
          "template": " ÓģĘ {{ .FormattedMs }} "
        },
        {
          "type": "session",
          "style": "powerline",
          "foreground": "#ffffff",
          "background": "#7194d1",
          "powerline_symbol": "Óāį",
          "template": " Ôíľ {{ .UserName }}"
        },
        {
          "type": "sysinfo",
          "powerline_symbol": "Óāį",
          "foreground": "#ffffff",
          "background": "#8f43f3",
          "template": " ÓČ¶ {{ round .PhysicalPercentUsed .Precision }}% ",
          "options": {
            "precision": 2
          },
          "style": "powerline"
        },
        {
          "type": "battery",
          "style": "diamond",
          "trailing_diamond": "Óāī",
          "foreground": "#193549",
          "background": "#ffeb3b",
          "background_templates": [
            "{{if eq \"Charging\" .State.String}}#40c4ff{{end}}",
            "{{if eq \"Discharging\" .State.String}}#ff5722{{end}}",
            "{{if eq \"Full\" .State.String}}#4caf50{{end}}"
          ],
          "template": " {{ if not .Error }}{{ .Icon }}{{ .Percentage }}{{ end }}Ôäē ",
          "options": {
            "discharging_icon": "ÓąĪ ",
            "charging_icon": "Óąī ",
            "charged_icon": "ÓąĮ "
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "os",
          "background": "#003543",
          "foreground": "#00c983",
          "leading_diamond": "Óā∂",
          "style": "diamond",
          "template": "{{ .Icon }} "
        },
        {
          "type": "path",
          "background": "#DA627D",
          "foreground": "#ffffff",
          "powerline_symbol": "Óāį",
          "options": {
            "folder_icon": "ÔĄē",
            "folder_separator_icon": "\\",
            "home_icon": "Ó¨Ü ",
            "style": "full"
          },
          "style": "powerline",
          "template": " <#000>ÔĀĽ Ó™ú</> {{ .Path }} "
        },
        {
          "type": "project",
          "style": "powerline",
          "powerline_symbol": "Óāį",
          "foreground": "#193549",
          "background": "#ffeb3b",
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ if .Version }}Ôíá {{.Version}}{{ end }} {{ if .Name }}{{ .Name }}{{ end }}{{ end }} "
        },
        {
          "type": "git",
          "background": "#FCA17D",
          "foreground": "#ffffff",
          "powerline_symbol": "Óāį",
          "options": {
            "branch_icon": " <#ffffff>Óā† </>",
            "fetch_status": false,
            "fetch_upstream_icon": true
          },
          "style": "powerline",
          "template": " ‚ěú ({{ .UpstreamIcon }}{{ .HEAD }}{{ if gt .StashCount 0 }} Ó≠č {{ .StashCount }}{{ end }}) "
        },
        {
          "type": "time",
          "background": "#33658A",
          "foreground": "#ffffff",
          "powerline_symbol": "Óāī",
          "options": {
            "time_format": "15:04"
          },
          "style": "powerline",
          "template": " ÔÄó {{ .CurrentDate | date .Format }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "leading_diamond": "Óā∂",
      "trailing_diamond": "Óāī",
      "filler": " -",
      "overflow": "hide",
      "segments": [
        {
          "type": "nix-shell",
          "style": "diamond",
          "foreground": "#ffffff",
          "background": "#6bd9f2",
          "trailing_diamond": "Óāį",
          "template": " ůĪĄÖ ({{ .Type }}) "
        },
        {
          "type": "python",
          "style": "diamond",
          "foreground": "#100e23",
          "background": "#906cff",
          "trailing_diamond": "Óāį",
          "template": " Óúľ {{ if .Error }}{{ .Error }}{{ else }}{{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }}{{ end }} "
        },
        {
          "type": "node",
          "style": "diamond",
          "foreground": "#ffffff",
          "background": "#6CA35E",
          "trailing_diamond": "Óāį",
          "template": " Óúė {{ .Full }} "
        },
        {
          "type": "bun",
          "style": "diamond",
          "background": "#3C82F6",
          "foreground": "#ffffff",
          "trailing_diamond": "Óāį",
          "template": " ÓĚĮ {{ .Full }} "
        },
        {
          "type": "npm",
          "style": "diamond",
          "foreground": "#ffffff",
          "background": "#a1a105",
          "trailing_diamond": "Óāį",
          "template": "Óúě {{ .Full }} "
        },
        {
          "type": "pnpm",
          "style": "diamond",
          "foreground": "#ffffff",
          "background": "#F9AD00",
          "trailing_diamond": "Óāį",
          "template": " ůįčĀ {{ .Full }} "
        },
        {
          "type": "yarn",
          "style": "diamond",
          "foreground": "#FFFFFF",
          "background": "#2E2A65",
          "trailing_diamond": "Óāį",
          "template": " ůįĄõ {{ .Full }} "
        },
        {
          "type": "react",
          "style": "diamond",
          "foreground": "#ffffff",
          "background": "#81a1c1",
          "template": " Óěļ {{ .Full }} ",
          "trailing_diamond": "Óāį"
        },
        {
          "type": "tauri",
          "style": "diamond",
          "foreground": "#000000",
          "background": "#1976d2",
          "trailing_diamond": "Óāį",
          "template": " ÓĘĽ {{ .Full }} "
        },
        {
          "type": "lua",
          "style": "diamond",
          "foreground": "white",
          "background": "blue",
          "trailing_diamond": "Óāį",
          "template": " Óė† {{ .Full }} "
        },
        {
          "type": "rust",
          "style": "diamond",
          "foreground": "#193549",
          "background": "#99908a",
          "trailing_diamond": "Óāį",
          "template": " Óě® {{ .Full }} "
        },
        {
          "type": "swift",
          "style": "diamond",
          "foreground": "#ffffff",
          "background": "#f6553c",
          "trailing_diamond": "Óāį",
          "template": " ÓĚē {{ .Full }} "
        }
      ]
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "template": " <#45F1C2><b>‚ö°</b></><#63db69><b>{{ .UserName }}</b></> <#26C6DA>‚ĚĮ</><#45F1C2>‚ĚĮ</>"
        }
      ],
      "type": "prompt"
    }
  ],
  "secondary_prompt": {
    "template": " <#45F1C2><b>Óėā </b></><#63db69><b>{{ .UserName }}</b></> <#26C6DA>‚ĚĮ</><#45F1C2>‚ĚĮ</>"
  },
  "debug_prompt": {
    "background": "transparent",
    "foreground": "#f23a71",
    "template": "Óęė (Debuging)"
  },
  "transient_prompt": {
    "background": "transparent",
    "foreground_templates": [
      "{{ if eq .Code 0 }}#63db69{{ end }}",
      "#f23a71"
    ],
    "template": "  <#45F1C2><b>Óėā </b></>(Exit with {{ .Code }}) "
  }
}
